---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeader from "../components/SectionHeader.astro";
import RouteStage from "../components/RouteStage.astro";
import { learningSections, routeStages } from "../data/ruta.js";
---

<BaseLayout title="Ruta de aprendizaje | Chilete DevPath">
  <section class="seccion page-hero seccion-clara">
    <div class="contenedor">
      <SectionHeader
        eyebrow="Ruta de aprendizaje"
        title="Aprender construyendo, paso a paso"
        description="Esta pagina organiza el avance tecnico de Chilete DevPath por etapas, contenido disponible y criterios de publicacion."
      />
    </div>
  </section>

  <section class="seccion">
    <div class="contenedor">
      <div class="ruta-etapas">
        {routeStages.map((stage) => <RouteStage stage={stage} />)}
      </div>
      <div class="ruta-accion">
        <p>El contenido practico vive en el repositorio de aprendizaje y seguira creciendo con ejercicios aprobados, desarrollados y revisados.</p>
        <a class="boton boton-principal" href="https://github.com/chiletedevpath/aprendizaje" target="_blank" rel="noopener">
          Abrir aprendizaje
        </a>
      </div>
    </div>
  </section>

  <section class="seccion seccion-clara">
    <div class="contenedor">
      <SectionHeader
        eyebrow="Contenido conectado"
        title="Entradas directas a la ruta"
        description="Cada bloque indica que esta disponible, que sigue creciendo y que requiere revision antes de publicarse como material para comunidad."
      />
      <div class="contenido-ruta">
        {learningSections.map((item) => (
          <article class="contenido-item">
            <span class="estado">{item.status}</span>
            <h3>{item.title}</h3>
            <p>{item.description}</p>
            <a href={item.href} target="_blank" rel="noopener">Abrir seccion</a>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
