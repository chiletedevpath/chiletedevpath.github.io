---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHero from "../../components/PageHero.astro";
import PolicyIcon from "../../components/PolicyIcon.astro";
import { policies } from "../../data/recursos.js";
---

<BaseLayout title="Politicas | Chilete DevPath">
  <PageHero
    eyebrow="Politicas internas"
    title="Criterios para publicar sin improvisar"
    description="Estas politicas convierten la marca en una practica responsable: autoria clara, privacidad, uso de IA, bienestar y seguridad."
    variant="criterios"
    visualTitle="Control editorial"
    visualText="Revision antes de publicar contenido publico."
  />

  <section class="seccion">
    <div class="contenedor politicas-grid">
      {policies.map((policy) => (
        <article class:list={["politica-documento", `politica-${policy.tone}`]}>
          <header class="politica-encabezado">
            <PolicyIcon name={policy.icon} />
            <div>
              <span class="politica-codigo">{policy.code}</span>
              <h3>{policy.title}</h3>
            </div>
          </header>
          <div class="politica-cuerpo">
            <p class="politica-destacado">{policy.highlight}</p>
            <p>{policy.objective}</p>
          </div>
          <a class="boton boton-principal" href={policy.href}>Abrir politica</a>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
