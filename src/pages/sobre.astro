---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
---

<BaseLayout title="Sobre Chilete DevPath | Adrian Pisco">
  <PageHero
    eyebrow="Sobre Chilete DevPath"
    title="Una marca personal con origen, camino y construccion"
    description="Chilete DevPath ordena mi aprendizaje, evidencia mi evolucion tecnica y prepara recursos utiles para otros estudiantes."
    variant="sobre"
    showVisual={false}
  />

  <section class="seccion">
    <div class="contenedor sobre-aura">
      <p class="aura-texto aura-uno">Soy Adrian Pisco, estudiante de Ingenieria de Sistemas e Informatica.</p>
      <p class="aura-texto aura-dos">Chilete DevPath representa mi ruta como futuro desarrollador Full Stack.</p>
      <div class="sobre-persona-pendiente" aria-label="Espacio pendiente para fotografia profesional de cuerpo completo">
        <span>Foto profesional pendiente</span>
      </div>
      <p class="aura-texto aura-tres">Tambien expresa mi camino como futuro ingeniero de sistemas.</p>
      <p class="aura-texto aura-cuatro">Mis raices en Chilete se conectan con aprendizaje tecnico, practica y comunidad.</p>
      <p class="aura-texto aura-cinco">Cada avance busca convertirse en evidencia real, recurso util y criterio profesional.</p>
    </div>
  </section>

  <section class="seccion seccion-clara">
    <div class="contenedor bloque-trabajo">
      <div>
        <p class="etiqueta">Forma de trabajo</p>
        <h2>Aprender, practicar, ordenar y compartir</h2>
        <p>
          Chilete DevPath no se construye como una vitrina vacia. Cada avance debe pasar por
          practica, documentacion, criterio de publicacion y revision antes de convertirse en
          contenido util para la comunidad.
        </p>
      </div>
      <p class="bloque-nota">
        La fotografia profesional se incorporara cuando exista una imagen real, sobria y coherente con la marca.
      </p>
    </div>
  </section>
</BaseLayout>
