---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import SectionHeader from "../components/SectionHeader.astro";
import { site } from "../data/site.js";

const principles = [
  {
    title: "Origen",
    text: "Chilete está en el nombre porque representa mi punto de partida. No es un adorno: es la raíz desde donde estoy construyendo esta marca.",
  },
  {
    title: "Ruta",
    text: "DevPath representa el camino: aprender por etapas, practicar, revisar y convertir el avance en algo que otros también puedan usar.",
  },
  {
    title: "Criterio",
    text: "No quiero publicar por publicar. Cada contenido debe entenderse, revisarse y aportar algo real a quien está aprendiendo.",
  },
];
---

<BaseLayout title="Sobre Chilete DevPath | Adrian Pisco">
  <PageHero
    eyebrow="Sobre Chilete DevPath"
    title="Una marca de aprendizaje técnico con origen, ruta y criterio"
    description="Chilete DevPath es la forma en la que estoy ordenando mi aprendizaje, mis proyectos y mis recursos para compartirlos con una comunidad que también quiere crecer."
    variant="sobre"
    visualTitle="Chilete + DevPath"
    visualText="Origen local, camino técnico y publicación responsable."
  />

  <section class="seccion seccion-clara">
    <div class="contenedor sobre-marca-grid">
      <div>
        <p class="etiqueta">Qué es Chilete DevPath</p>
        <h2>Mi ruta de aprendizaje convertida en un ecosistema público</h2>
        <p>
          Chilete DevPath no nació para ser una lista de enlaces. Nació para ordenar lo que voy aprendiendo
          como estudiante de Ingeniería de Sistemas e Informática y futuro desarrollador Full Stack.
        </p>
        <p>
          Aquí quiero que cada persona pueda encontrar una ruta clara: entender la base, practicar con ejercicios,
          revisar proyectos con contexto y aprender a publicar sin descuidar autoría, privacidad ni criterio técnico.
        </p>
        <div class="sobre-claves">
          <span>Ruta antes que desorden</span>
          <span>Evidencia antes que apariencia</span>
          <span>Comunidad antes que vitrina</span>
        </div>
      </div>
      <div class="mapa-identidad">
        <span>Origen de la marca</span>
        <strong>{site.location}</strong>
        <p>
          Chilete es mi punto de partida. Lo menciono como identidad personal y territorial,
          sin usar marcas institucionales ni atribuirme representación oficial.
        </p>
        <a class="boton boton-secundario boton-mapa" href={site.mapsHref} target="_blank" rel="noopener">
          Abrir ubicación en el mapa
        </a>
      </div>
    </div>
  </section>

  <section class="seccion">
    <div class="contenedor">
      <SectionHeader
        eyebrow="Diferencia de marca"
        title="La web debe explicar el camino, no decorar el camino"
        description="Cada sección existe para orientar: aprender, practicar, evidenciar, publicar y compartir con responsabilidad."
      />
      <div class="tarjetas tarjetas-3">
        {principles.map((item) => (
          <article class="tarjeta valor-card">
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
