---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import { policies } from "../data/recursos.js";
---

<BaseLayout title="Criterios | Chilete DevPath">
  <PageHero
    eyebrow="Criterios"
    title="Aprender tambien implica publicar con responsabilidad"
    description="Las politicas protegen autoria, fuentes, privacidad, bienestar, IA y seguridad antes de convertir contenido en material publico."
    variant="criterios"
    visualTitle="Gobierno de marca"
    visualText="Politicas para publicar con autoria, privacidad y criterio profesional."
  />

  <section class="seccion">
    <div class="contenedor">
      <div class="politicas-grid">
        {policies.map((policy) => (
          <article class="politica-documento">
            <header class="politica-encabezado">
              <img src="/assets/img/marca-simbolo-nav.png" width="512" height="512" alt="" />
              <div>
                <span>{policy.code}</span>
                <h3>{policy.title}</h3>
              </div>
            </header>
            <dl class="politica-detalle">
              <div>
                <dt>Objetivo</dt>
                <dd>{policy.objective}</dd>
              </div>
              <div>
                <dt>Alcance</dt>
                <dd>{policy.scope}</dd>
              </div>
              <div>
                <dt>Responsable</dt>
                <dd>{policy.owner}</dd>
              </div>
              <div>
                <dt>Version</dt>
                <dd>{policy.version} - {policy.status}</dd>
              </div>
            </dl>
            <a class="boton boton-principal" href={policy.href} target="_blank" rel="noopener">Abrir politica</a>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
