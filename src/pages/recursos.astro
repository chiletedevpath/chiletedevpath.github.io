---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import SectionHeader from "../components/SectionHeader.astro";
import { resources } from "../data/recursos.js";
---

<BaseLayout title="Recursos | Chilete DevPath">
  <PageHero
    eyebrow="Recursos"
    title="Practica, revisa y avanza con material organizado"
    description="Esta sección reúne material para practicar y consultar sin perderse entre carpetas: ejercicios, retos, glosarios y criterios."
    variant="recursos"
    visualTitle="Biblioteca DevPath"
    visualText="Material para resolver, estudiar y publicar con criterio."
  />

  <section class="seccion">
    <div class="contenedor">
      <SectionHeader
        eyebrow="Cómo usar esta sección"
        title="Elige el recurso según tu momento de aprendizaje"
        description="Si estás practicando, empieza por retos. Si ya lo intentaste, revisa ejercicios desarrollados. Si un concepto no queda claro, consulta el glosario."
      />
      <div class="tarjetas tarjetas-4">
        {resources.map((resource) => (
          <article class="tarjeta recurso-card">
            <span class="estado">{resource.status}</span>
            <small>{resource.type}</small>
            <h3>{resource.title}</h3>
            <p>{resource.description}</p>
            <a href={resource.href} target={resource.href.startsWith("http") ? "_blank" : undefined} rel={resource.href.startsWith("http") ? "noopener" : undefined}>
              Ver recurso
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="seccion seccion-clara">
    <div class="contenedor contacto-grid">
      <div>
        <p class="etiqueta">Sugerencias de recursos</p>
        <h2>Ayúdame a priorizar qué material falta</h2>
        <p>
          Si hay un tema que debería tener ejercicios, glosario o laboratorio, envíame la idea.
          La revisaré antes de publicarla para que realmente aporte a la ruta.
        </p>
      </div>
      <div class="formulario-contacto panel-contacto formulario-recursos" data-contact-panel data-context="Sugerencia de recurso">
        <p class="formulario-intro">La sugerencia se enviará por correo para revisarla con calma antes de convertirla en contenido público.</p>
        <label>
          Tema sugerido
          <input type="text" name="tema" required />
        </label>
        <label>
          Tipo de recurso
          <select name="tipo" required>
            <option value="Ejercicio">Ejercicio</option>
            <option value="Reto">Reto</option>
            <option value="Glosario">Glosario</option>
            <option value="Guía">Guía</option>
          </select>
        </label>
        <label>
          Motivo
          <textarea name="motivo" rows="5" required></textarea>
        </label>
        <div class="acciones-formulario">
          <button class="boton boton-principal" type="button" data-send-email>Enviar idea por correo</button>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
