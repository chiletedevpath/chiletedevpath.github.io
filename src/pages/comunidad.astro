---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import SectionHeader from "../components/SectionHeader.astro";
import SocialIcon from "../components/SocialIcon.astro";
import { socials } from "../data/site.js";
---

<BaseLayout title="Comunidad | Chilete DevPath">
  <PageHero
    eyebrow="Comunidad"
    title="Aprender acompañado hace el camino más sostenible"
    description="Quiero que Chilete DevPath también sea un espacio para compartir avances, dudas y aprendizajes sin perder el criterio."
    variant="comunidad"
    visualTitle="Red de aprendizaje"
    visualText="Canales para compartir avance, dudas y aprendizaje responsable."
  />

  <section class="seccion contacto">
    <div class="contenedor">
      <SectionHeader
        eyebrow="Canales oficiales"
        title="Sigue el avance por el canal que uses mejor"
        description="GitHub guarda la evidencia técnica. Las redes me ayudan a explicar el proceso, compartir avances y acercar la ruta a más estudiantes."
      />
      <div class="redes" aria-label="Canales oficiales de Chilete DevPath">
        {socials.map((social) => (
          <a class={social.primary ? "red-social red-social-principal" : "red-social"} href={social.href} target="_blank" rel="noopener">
            <SocialIcon name={social.name} />
            <span>{social.label}</span>
            <strong>{social.name}</strong>
            <small>{social.description}</small>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="seccion seccion-clara">
    <div class="contenedor contacto-grid">
      <div>
        <p class="etiqueta">Feedback de comunidad</p>
        <h2>Cuéntame qué mejorarías</h2>
        <p>
          Si ves un tema confuso, una sección incompleta o una idea que pueda ayudar a otros,
          déjame la sugerencia por correo. Prefiero revisar cada aporte antes de publicarlo.
        </p>
      </div>
      <div class="formulario-contacto panel-contacto formulario-feedback" data-contact-panel data-context="Feedback de comunidad">
        <p class="formulario-intro">Este espacio es para sugerencias concretas. Mientras no exista backend, las revisaré por correo.</p>
        <label>
          Nombre
          <input type="text" name="nombre" autocomplete="name" required />
        </label>
        <label>
          Correo
          <input type="email" name="correo" autocomplete="email" required />
        </label>
        <label>
          Sugerencia
          <textarea name="sugerencia" rows="5" required></textarea>
        </label>
        <div class="acciones-formulario">
          <button class="boton boton-principal" type="button" data-send-email>Enviar sugerencia por correo</button>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
