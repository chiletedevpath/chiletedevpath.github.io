---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import ProjectCard from "../components/ProjectCard.astro";
import SectionHeader from "../components/SectionHeader.astro";
import { academicProjects, projectAreas } from "../data/proyectos.js";
---

<BaseLayout title="Proyectos | Chilete DevPath">
  <PageHero
    eyebrow="Proyectos"
    title="Evidencia técnica sin confundir avance con portafolio"
    description="Aquí muestro proyectos con contexto: qué aprendí, en qué estado están y por qué todavía no todo debe presentarse como portafolio final."
    variant="proyectos"
    visualTitle="Evidencia en construcción"
    visualText="Proyectos y documentación con criterio."
    imageSrc="/assets/img/heros/proyectos.png"
    imageAlt="Escritorio de trabajo con laptop, apuntes y documentación técnica de proyectos."
  />

  <section class="seccion">
    <div class="contenedor">
      <SectionHeader
        eyebrow="Mapa del ecosistema"
        title="Primero se aprende, luego se evidencia, después se selecciona"
        description="No quiero mezclar ejercicios, entregas académicas y portafolio profesional. Cada cosa tiene su lugar para que el avance se entienda mejor."
      />
      <div class="tarjetas tarjetas-3">
        {projectAreas.map((project) => <ProjectCard project={project} />)}
      </div>
    </div>
  </section>

  <section class="seccion seccion-clara">
    <div class="contenedor">
      <SectionHeader
        eyebrow="Evidencia revisada"
        title="Proyectos académicos con contexto"
        description="Estos proyectos muestran mi avance académico. Algunos están terminados, otros siguen en proceso, y todos deben cuidarse antes de convertirse en material público."
      />
      <div class="tarjetas tarjetas-3">
        {academicProjects.map((project) => <ProjectCard project={project} />)}
      </div>
    </div>
  </section>
</BaseLayout>
