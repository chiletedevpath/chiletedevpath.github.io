---
const { variant = "ruta", title = "Visual Chilete DevPath" } = Astro.props;
---

<div class={`section-visual section-visual-${variant}`} aria-label={title}>
  <svg viewBox="0 0 640 420" role="img" aria-labelledby={`visual-${variant}-title`}>
    <title id={`visual-${variant}-title`}>{title}</title>
    <defs>
      <linearGradient id={`linea-${variant}`} x1="0" x2="1" y1="0" y2="1">
        <stop offset="0%" stop-color="var(--color-progreso)" />
        <stop offset="52%" stop-color="var(--color-acento)" />
        <stop offset="100%" stop-color="var(--color-agua)" />
      </linearGradient>
      <filter id={`brillo-${variant}`} x="-20%" y="-20%" width="140%" height="140%">
        <feGaussianBlur stdDeviation="4" result="blur" />
        <feMerge>
          <feMergeNode in="blur" />
          <feMergeNode in="SourceGraphic" />
        </feMerge>
      </filter>
    </defs>

    <rect class="visual-fondo" x="0" y="0" width="640" height="420" rx="22" />
    <path class="visual-malla" d="M42 334 C140 248 196 306 278 214 S438 130 582 72" />
    <path class="visual-camino" d="M58 350 C152 286 216 292 292 220 C368 148 448 134 584 78" filter={`url(#brillo-${variant})`} />

    {variant === "ruta" && (
      <>
        {[86, 196, 314, 438, 548].map((x, index) => (
          <g class="visual-nodo">
            <circle cx={x} cy={330 - index * 56} r="20" />
            <rect x={x - 42} y={356 - index * 56} width="84" height="34" rx="10" />
          </g>
        ))}
        <path class="visual-raiz" d="M328 256 v-92 m0 92 c-46-18-74-48-86-90 m86 90 c42-22 72-56 92-100" />
      </>
    )}

    {variant === "proyectos" && (
      <>
        {[72, 230, 388].map((x, index) => (
          <g class="visual-card">
            <rect x={x} y={88 + index * 38} width="148" height="112" rx="16" />
            <path d={`M${x + 22} ${118 + index * 38}h74M${x + 22} ${144 + index * 38}h98M${x + 22} ${170 + index * 38}h56`} />
          </g>
        ))}
        <path class="visual-conexion" d="M174 148h62M330 186h62M262 244h112" />
      </>
    )}

    {variant === "recursos" && (
      <>
        <g class="visual-card visual-libro">
          <rect x="90" y="100" width="126" height="176" rx="14" />
          <path d="M122 136h62M122 166h48M122 196h70" />
        </g>
        <g class="visual-card visual-libro">
          <rect x="256" y="78" width="126" height="198" rx="14" />
          <path d="M288 118h62M288 148h42M288 178h72" />
        </g>
        <g class="visual-card visual-libro">
          <rect x="422" y="118" width="126" height="158" rx="14" />
          <path d="M454 154h62M454 184h48M454 214h68" />
        </g>
      </>
    )}

    {variant === "criterios" && (
      <>
        <g class="visual-card visual-doc">
          <rect x="118" y="74" width="170" height="232" rx="16" />
          <path d="M152 126h92M152 164h72M152 202h96M152 240h54" />
        </g>
        <path class="visual-escudo" d="M402 82 512 126v82c0 72-42 116-110 144-68-28-110-72-110-144v-82Z" />
        <path class="visual-check" d="m354 206 34 34 76-88" />
      </>
    )}

    {variant === "comunidad" && (
      <>
        {[126, 244, 382, 510, 318].map((x, index) => (
          <g class="visual-persona">
            <circle cx={x} cy={118 + (index % 3) * 78} r="22" />
            <path d={`M${x - 34} ${158 + (index % 3) * 78}c18-24 50-24 68 0`} />
          </g>
        ))}
        <path class="visual-conexion" d="M146 126 244 196 382 118 510 274 318 274 244 196" />
      </>
    )}

    {variant === "sobre" && (
      <>
        <path class="visual-raiz visual-raiz-grande" d="M320 322V112m0 210c-62-34-100-86-124-160m124 160c64-36 104-92 132-178M320 322c-38 24-74 42-128 48m128-48c42 28 88 42 144 48" />
        <circle class="visual-origen" cx="320" cy="318" r="34" />
        <rect class="visual-chip" x="236" y="74" width="168" height="52" rx="14" />
      </>
    )}
  </svg>
</div>
