---
---

<section id="inicio" class="hero">
  <div class="contenedor hero-contenido">
    <div class="hero-texto">
      <p class="etiqueta">Chilete, Cajamarca, Peru | Desarrollo Full Stack</p>

      <h1>Chilete DevPath</h1>

      <p class="hero-descripcion">
        Soy Adrian Pisco, estudiante de Ingenieria de Sistemas e Informatica. Construyo
        Chilete DevPath como una ruta publica donde mi aprendizaje, mis proyectos y mi
        criterio tecnico se convierten en evidencia real para crecer con la comunidad.
      </p>

      <div class="acciones">
        <a class="boton boton-principal" href="/ruta/">Ver ruta de aprendizaje</a>
        <a class="boton boton-secundario" href="https://github.com/chiletedevpath" target="_blank" rel="noopener">
          Explorar GitHub
        </a>
      </div>

      <div class="hero-indicadores" aria-label="Resumen de la marca">
        <span>Origen con identidad</span>
        <span>Ruta tecnica visible</span>
        <span>Comunidad en construccion</span>
      </div>
    </div>

    <div class="hero-visual">
      <div class="hero-imagen">
        <img
          src="/assets/img/marca-banner-principal.png"
          width="1536"
          height="815"
          alt="Banner de marca Chilete DevPath"
        />
        <div class="hero-marca-panel" aria-label="Enfoque de Chilete DevPath">
          <div>
            <span>Origen</span>
            <strong>Chilete</strong>
          </div>
          <div>
            <span>Ruta</span>
            <strong>Aprendizaje</strong>
          </div>
          <div>
            <span>Construye</span>
            <strong>Proyectos</strong>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
