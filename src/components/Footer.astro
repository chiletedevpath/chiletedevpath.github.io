---
import { navItems, navMoreItems, site, socials } from "../data/site.js";
import { policies } from "../data/recursos.js";
import SocialIcon from "./SocialIcon.astro";
---

<footer class="pie">
  <div class="pie-contenido">
    <div class="pie-marca">
      <img src="/assets/img/marca-simbolo-nav.png" width="512" height="512" alt="" />
      <div>
        <strong>{site.name}</strong>
        <p>Desarrollado desde Chilete, Cajamarca, Peru para compartir aprendizaje tecnico con criterio.</p>
      </div>
    </div>

    <nav class="pie-columna" aria-label="Enlaces rapidos">
      <strong>Navegacion</strong>
      {[...navItems, ...navMoreItems].map((item) => <a href={item.href}>{item.label}</a>)}
    </nav>

    <nav class="pie-columna" aria-label="Politicas de Chilete DevPath">
      <strong>Politicas</strong>
      {policies.map((policy) => <a href={policy.href}>{policy.title}</a>)}
    </nav>

    <div class="pie-social">
      <p>Unete a Discord o revisa el avance publico en GitHub.</p>
      <nav class="pie-redes" aria-label="Redes oficiales">
        {socials.map((social) => (
          <a href={social.href} target="_blank" rel="noopener" aria-label={social.name}>
            <SocialIcon name={social.name} />
          </a>
        ))}
      </nav>
      <span class="version-marca">{site.version}</span>
    </div>
  </div>
  <div class="pie-inferior">
    <span>Chilete DevPath por Adrian Pisco.</span>
    <span>© 2024-2026</span>
  </div>
</footer>
